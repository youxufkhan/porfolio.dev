---
import LinkInline from "./LinkInline.astro"
import ArrowRight from "./icons/ArrowRight.astro"

interface Props {
  title: string
  company: string
  description: string
  link?: string
  date: string
  current?: boolean
}

const { title, company, description, link, date, current = false } = Astro.props
---

<div
  class="relative mx-12 pb-12 grid before:absolute before:left-[-35px] before:block before:h-full before:border-l-2 before:border-gray-200 dark:before:border-white/10 before:content-[''] md:grid-cols-5 md:gap-10 md:space-x-4"
>
  <div class="relative pb-12 md:col-span-2">
    <div class="sticky top-0">
      <div class="flex items-center">
        <span
          class="absolute -left-[42px] flex size-[14px] items-center justify-center"
          aria-hidden="true"
        >
          {current && (
            <span class="animate-ping motion-reduce:animate-none absolute inline-flex size-full rounded-full bg-gray-400/40 dark:bg-white/40"></span>
          )}
          <span
            class={`relative inline-flex size-[10px] rounded-full bg-gray-900 dark:bg-white ${current ? "shadow-[0_0_8px_2px_rgba(0,0,0,0.1)] dark:shadow-[0_0_8px_2px_rgba(255,255,255,0.2)]" : ""}`}
          ></span>
        </span>
        <h3 class="text-xl font-bold text-gray-900 dark:text-white">{title}</h3>
      </div>
      <h4 class="font-semibold text-lg text-gray-700 dark:text-gray-300 mt-1">{company}</h4>
      <time class="p-0 m-0 text-sm font-mono text-gray-500 dark:text-gray-400 mt-2 block">{date}</time>
    </div>
  </div>
  <div class="relative flex flex-col gap-2 pb-4 text-gray-600 dark:text-gray-300 md:col-span-3 leading-relaxed max-w-[65ch]">
    {description}
    {
      link && (
        <LinkInline href={link}>
          Learn more about {company}{" "}
          <ArrowRight class="size-5" aria-hidden="true" />
        </LinkInline>
      )
    }
  </div>
</div>
