---
import GitHub from "./icons/GitHub.astro"
import ExternalLink from "./icons/ExternalLink.astro"
import LinkButton from "./LinkButton.astro"
import projectsData from "@/data/projects.json"
---

<div class="flex flex-col gap-y-12">
  {
    projectsData.map(({ logoImage, title, description, domain, contribution, tags, link, github }) => (
      <article class="flex flex-col md:flex-row gap-8 p-6 md:p-8 rounded-[2rem] bg-white dark:bg-gray-900 ring-1 ring-gray-200 dark:ring-white/10 shadow-[0_20px_40px_-15px_rgba(0,0,0,0.05)] transition-transform hover:-translate-y-1">
        <div class="flex-shrink-0">
          <img alt={title} class="size-16 md:size-24 object-contain rounded-xl bg-gray-50 dark:bg-gray-800/50 p-2 ring-1 ring-gray-100 dark:ring-white/5" loading="lazy" src={logoImage} />
        </div>
        
        <div class="flex-1 flex flex-col justify-center">
          <h3 class="text-2xl font-bold text-gray-900 dark:text-gray-100 flex items-center gap-3">
            {title}
            <span class="text-xs font-medium text-gray-600 dark:text-gray-300 bg-gray-100 dark:bg-white/10 px-3 py-1 rounded-full">{domain}</span>
          </h3>
          
          <ul class="flex flex-row flex-wrap mt-4 gap-2">
            {tags.map((tag) => (
              <li>
                <span class="rounded-full text-xs font-mono tracking-tight bg-gray-50 dark:bg-white/5 ring-1 ring-gray-200 dark:ring-white/10 text-gray-600 dark:text-gray-300 py-1 px-3">
                  {tag}
                </span>
              </li>
            ))}
          </ul>
          
          <p class="mt-6 text-gray-700 dark:text-gray-300 leading-relaxed max-w-[65ch] text-pretty">
            {description}
          </p>
          
          <div class="mt-6 text-sm text-gray-600 dark:text-gray-400 leading-relaxed max-w-[65ch] border-l-2 border-gray-200 dark:border-white/10 pl-4">
            <strong class="text-gray-900 dark:text-white font-semibold">Impact: </strong>{contribution}
          </div>
          
          <footer class="flex items-center mt-6 gap-x-4">
            {github && (
              <LinkButton href={github}>
                <GitHub class="size-5" />
                Code
              </LinkButton>
            )}
            {link && (
              <LinkButton href={link}>
                <ExternalLink class="size-4" />
                Preview
              </LinkButton>
            )}
          </footer>
        </div>
      </article>
    ))
  }
</div>
